<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Chromium-based browsers use a non-standard accessibility implementation
	     that does not fire reliable AX value-changed notifications. TextMonitor
	     uses polling for these apps instead (D-02). -->
	<key>com.google.Chrome</key>
	<dict>
		<key>notificationUnreliable</key>
		<true/>
	</dict>

	<!-- VS Code is an Electron app with the same notification reliability issues
	     as Chrome (shares the same Chromium accessibility stack). -->
	<key>com.microsoft.VSCode</key>
	<dict>
		<key>notificationUnreliable</key>
		<true/>
	</dict>

	<!-- Generic Electron shell — covers any Electron-based app not individually listed. -->
	<key>com.github.Electron</key>
	<dict>
		<key>notificationUnreliable</key>
		<true/>
	</dict>
</dict>
</plist>
